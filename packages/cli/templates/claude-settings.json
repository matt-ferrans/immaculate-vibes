{
  "$iv": "iv:managed — generated by `immaculate-vibes init`. JSON can't carry a comment, so this _$iv key marks the file as IV-managed; .iv/manifest.json is the authoritative record. Safe to edit; sync will report drift.",
  "permissions": {
    "allow": [
      "Bash(git status:*)",
      "Bash(git diff:*)",
      "Bash(git log:*)",
      "Bash(git add:*)",
      "Bash(git commit:*)",
      "Bash(git push -u origin claude/*)",
      "Bash(git push origin claude/*)",
      "Bash(npm:*)",
      "Bash(npx iv-gate:*)",
      "Bash(node:*)"
    ],
    "ask": [
      "Bash(git rebase:*)",
      "Bash(git commit --amend:*)",
      "Bash(rm -rf:*)",
      "Bash(npm uninstall:*)"
    ],
    "deny": [
      "Bash(git push --force:*)",
      "Bash(git push -f:*)",
      "Bash(git push --force-with-lease:*)",
      "Bash(git push --no-verify:*)",
      "Bash(git push --mirror:*)",
      "Bash(git push --delete:*)",
      "Bash(git push --tags:*)",
      "Bash(git push origin main:*)",
      "Bash(git push origin master:*)",
      "Bash(git push -u origin main:*)",
      "Bash(git push -u origin master:*)",
      "Bash(git reset --hard:*)",
      "Bash(git branch -D:*)",
      "Bash(git commit --no-verify:*)",
      "Bash(sudo:*)",
      "Bash(curl:*| sh:*)",
      "Bash(wget:*| sh:*)"
    ]
  },
  "hooks": {}
}
